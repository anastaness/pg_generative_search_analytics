<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <title>{{ page_title }}</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --card-bg: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --grid: #e5e7eb;

      --pg: #ce0d8a;
      --pg-top: #ff78ca;

      --competitor: #00a3e4;
      --competitor-top: #6ed6ff;

      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top left, #eef4ff 0%, transparent 30%),
        radial-gradient(circle at top right, #fff4df 0%, transparent 28%),
        var(--bg);
      color: var(--text);
    }

    .page {
      width: 1600px;
      min-height: 980px;
      padding: 42px;
    }

    .header {
      margin-bottom: 28px;
    }

    .eyebrow {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: #e8eefc;
      color: #3156b8;
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .title {
      margin: 0;
      font-size: 40px;
      line-height: 1.15;
      font-weight: 800;
    }

    .subtitle {
      margin-top: 10px;
      font-size: 20px;
      color: var(--muted);
    }

    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 34px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg, var(--pg-top), var(--competitor-top));
    }

    .card-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 24px;
    }

    .chart-title {
      margin: 0 0 8px;
      font-size: 30px;
      font-weight: 800;
    }

    .chart-caption {
      margin: 0;
      color: var(--muted);
      font-size: 18px;
    }

    .max-box {
      min-width: 220px;
      padding: 18px 20px;
      border-radius: 18px;
      background: linear-gradient(180deg, #fafcff 0%, #f8fafc 100%);
      border: 1px solid #edf1f5;
      text-align: right;
    }

    .max-label {
      font-size: 15px;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 8px;
    }

    .max-value {
      font-size: 34px;
      line-height: 1;
      font-weight: 800;
    }

    .plot-wrap {
      padding: 24px;
      border-radius: 22px;
      background: linear-gradient(180deg, #fafcff 0%, #f8fafc 100%);
      border: 1px solid #edf1f5;
    }

    .rows {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .row {
      display: grid;
      grid-template-columns: 80px 300px 1fr 140px;
      align-items: center;
      gap: 18px;
    }

    .rank {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 800;
      color: var(--muted);
      background: #f3f6fa;
      border: 1px solid #e9eef5;
    }

    .rank.top {
      color: white;
      background: linear-gradient(180deg, var(--pg-top) 0%, var(--pg) 100%);
      border: none;
      box-shadow: 0 8px 18px rgba(206, 13, 138, 0.22);
    }

    .domain {
      font-size: 24px;
      font-weight: 800;
      line-height: 1.2;
      word-break: break-word;
    }

    .bar-track {
      width: 100%;
      height: 36px;
      border-radius: 999px;
      background: #edf2f7;
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
    }

    .bar-fill {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      min-width: 16px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--competitor-top) 0%, var(--competitor) 100%);
    }

    .row.top .bar-fill {
      background: linear-gradient(90deg, var(--pg-top) 0%, var(--pg) 100%);
      box-shadow: 0 8px 18px rgba(206, 13, 138, 0.18);
    }

    .value {
      text-align: right;
      font-size: 24px;
      font-weight: 800;
    }

    .footnote {
      margin-top: 18px;
      font-size: 15px;
      color: #94a3b8;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <div class="eyebrow">{{ eyebrow }}</div>
      <h1 class="title">{{ main_title }}</h1>
      <div class="subtitle">{{ subtitle }}</div>
    </div>

    <section class="card">
      <div class="card-head">
        <div>
          <h2 class="chart-title">Рейтинг источников</h2>
          <p class="chart-caption">Ранжирование источников по доле упоминаний в ответах.</p>
        </div>

        <div class="max-box">
          <div class="max-label">Максимальная доля</div>
          <div class="max-value">{{ max_value }}</div>
        </div>
      </div>

      <div class="plot-wrap">
        <div class="rows">
          {% for row in rows %}
          <div class="row {% if row.is_top %}top{% endif %}">
            <div class="rank {% if row.is_top %}top{% endif %}">{{ row.rank }}</div>
            <div class="domain">{{ row.domain }}</div>
            <div class="bar-track">
              <div class="bar-fill" style="width: {{ '%.2f'|format(row.width_pct) }}%;"></div>
            </div>
            <div class="value">{{ row.value_str }}</div>
          </div>
          {% endfor %}
        </div>


      </div>
    </section>
  </div>
</body>
</html>