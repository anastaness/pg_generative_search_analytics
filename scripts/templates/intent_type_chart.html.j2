<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <title>{{ page_title }}</title>
  <style>
    :root {
      --bg: #fdf7fc;
      --card-bg: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --grid: #f3d3ea;

      /* основная палитра */
      --pg: #ce0d8a;
      --pg-top: #ff78ca;

      --competitor: #00a3e4;
      --competitor-top: #6ed6ff;

      --accent: #ff78ca;
      --accent-soft: #fff0fa;
      --pg-soft: #fbe4f3;
      --competitor-soft: #e8f7fd;

      --shadow: 0 10px 30px rgba(206, 13, 138, 0.10);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(206, 13, 138, 0.10) 0%, transparent 30%),
        radial-gradient(circle at top right, rgba(0, 163, 228, 0.10) 0%, transparent 28%),
        radial-gradient(circle at bottom center, rgba(255, 120, 202, 0.10) 0%, transparent 34%),
        var(--bg);
      color: var(--text);
    }

    .page {
      width: 1600px;
      min-height: 900px;
      padding: 42px;
    }

    .header {
      margin-bottom: 28px;
    }

    .eyebrow {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--pg-soft);
      color: var(--pg);
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .title {
      margin: 0;
      font-size: 40px;
      line-height: 1.15;
      font-weight: 800;
    }

    .subtitle {
      margin-top: 10px;
      font-size: 20px;
      color: var(--muted);
    }

    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 34px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg, var(--pg), var(--competitor), var(--accent));
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 26px;
    }

    .chart-title {
      font-size: 30px;
      font-weight: 800;
      margin: 0 0 8px;
    }

    .chart-caption {
      margin: 0;
      font-size: 18px;
      color: var(--muted);
    }

    .legend {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      align-items: center;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 17px;
      color: var(--muted);
      font-weight: 700;
    }

    .legend-swatch {
      width: 16px;
      height: 16px;
      border-radius: 4px;
    }

    .legend-swatch.pg {
      background: var(--pg);
    }

    .legend-swatch.competitor {
      background: var(--competitor);
    }

    .plot-wrap {
      padding: 26px;
      border-radius: 22px;
      background: linear-gradient(180deg, #fff8fc 0%, #f8fcff 100%);
      border: 1px solid var(--grid);
    }

    .scale {
      display: grid;
      grid-template-columns: 220px 1fr 90px 120px;
      align-items: center;
      margin-bottom: 12px;
      color: #9ca3af;
      font-size: 14px;
      font-weight: 700;
    }

    .scale-bar {
      position: relative;
      height: 1px;
      background: transparent;
      margin-right: 18px;
    }

    .scale-ticks {
      display: flex;
      justify-content: space-between;
      margin-right: 18px;
    }

    .rows {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .row {
      display: grid;
      grid-template-columns: 220px 1fr 90px 120px;
      align-items: center;
      gap: 0;
    }

    .row-label {
      font-size: 22px;
      font-weight: 800;
      text-transform: lowercase;
    }

    .bar-area {
      padding-right: 18px;
    }

    .track {
      position: relative;
      width: 100%;
      height: 46px;
      border-radius: 999px;
      background: #f8eaf3;
      overflow: hidden;
      box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
    }

    .bar-pg {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      min-width: 18px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--pg-top) 0%, var(--pg) 100%);
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 14px;
      color: white;
      font-size: 18px;
      font-weight: 800;
    }

    .bar-competitor {
      position: absolute;
      top: 8px;
      bottom: 8px;
      min-width: 0;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--competitor-top) 0%, var(--competitor) 100%);
      box-shadow: 0 0 0 2px rgba(255,255,255,0.9);
    }

    .pg-value,
    .competitor-value {
      font-size: 20px;
      font-weight: 800;
      text-align: right;
    }

    .pg-value {
      color: var(--text);
    }

    .competitor-value {
      color: var(--muted);
    }

    .competitor-value.empty {
      color: #d8b4d0;
    }

    .footnote {
      margin-top: 18px;
      font-size: 15px;
      color: #9ca3af;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <div class="eyebrow">Сравнительный спрос</div>
      <h1 class="title">{{ main_title }}</h1>
      <div class="subtitle">{{ subtitle }}</div>
    </div>

    <section class="card">
      <div class="card-head">
        <div>
          <h2 class="chart-title">Брендовый спрос</h2>
        </div>

        <div class="legend">
          <div class="legend-item">
            <span class="legend-swatch pg"></span>
            <span>P&amp;G</span>
          </div>
          <div class="legend-item">
            <span class="legend-swatch competitor"></span>
            <span>конкуренты</span>
          </div>
        </div>
      </div>

      <div class="plot-wrap">
        <div class="scale">
          <div></div>
          <div class="scale-ticks">
            <span>0</span>
            <span>{{ (max_value / 3) | round(1) }}</span>
            <span>{{ ((max_value / 3) * 2) | round(1) }}</span>
            <span>{{ max_value }}</span>
          </div>
          <div style="text-align:right;">P&amp;G</div>
          <div style="text-align:right;">конкуренты</div>
        </div>

        <div class="rows">
          {% for row in rows %}
          <div class="row">
            <div class="row-label">{{ row.label }}</div>

            <div class="bar-area">
              <div class="track">
                <div class="bar-pg" style="width: {{ '%.2f'|format(row.pg_width_pct) }}%;">
                  {% if row.pg_width_pct >= 18 %}
                  <span>{{ row.pg }}</span>
                  {% endif %}
                </div>

                {% if row.competitor > 0 %}
                <div
                  class="bar-competitor"
                  style="
                    left: calc({{ '%.2f'|format(row.pg_width_pct) }}% - {{ 8 if row.pg_width_pct > 8 else 0 }}px);
                    width: {{ '%.2f'|format(row.competitor_width_pct) }}%;
                    min-width: 18px;
                  "
                  title="competitor: {{ row.competitor }}"
                ></div>
                {% endif %}
              </div>
            </div>

            <div class="pg-value">{{ row.pg }}</div>

            {% if row.competitor > 0 %}
            <div class="competitor-value">{{ row.competitor }}</div>
            {% else %}
            <div class="competitor-value empty">-</div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  </div>
</body>
</html>